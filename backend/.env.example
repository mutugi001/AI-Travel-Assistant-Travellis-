# Server
PORT=4000

# --- LLM Provider ---
# Choose "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Anthropic (used if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI (used if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# --- Storage ---
# If MONGODB_URI is set, the app uses MongoDB (works with a Supabase/Mongo Atlas
# connection string too, as long as it's a Mongo-compatible URI, or point this at
# your own Mongo Atlas / local Mongo instance).
# If left empty, the app falls back to a local JSON file store at backend/data/
# so the project runs with zero external setup.
MONGODB_URI=

# Minimum lead score (0-100) required, together with name+phone, before a
# conversation is persisted as a fully "qualified" lead.
LEAD_QUALIFY_THRESHOLD=50
